# Normalize line endings to LF in the repo, native on checkout
* text=auto

# Force LF for all source code (prevents OneDrive CRLF conversion from polluting diffs)
*.m text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.xrdml text eol=lf

# Data files that should also be normalized
*.dat text eol=lf
*.out text eol=lf
*.par text eol=lf
*.refl text eol=lf
*.pnr text eol=lf
*.datA text eol=lf
*.datB text eol=lf
*.datC text eol=lf
*.datD text eol=lf

# Truly binary files — never touch
*.mat binary
*.raw binary
*.brml binary
*.dm3 binary
*.dm4 binary
*.tif binary
*.tiff binary
*.png binary
*.jpg binary
*.pdf binary
